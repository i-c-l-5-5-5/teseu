{
  "name": "barqueiro",
  "version": "0.1.0",
  "description": "Bot do Discord com sistema de perfis personalizáveis, ranking por mensagens, embeds unificadas e quiz interativo",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Italo C Lopes",
  "homepage": "https://github.com/ascentusoss/barqueiro",
  "repository": {
    "type": "git",
    "url": "https://github.com/ascentusoss/barqueiro.git"
  },
  "bugs": {
    "url": "https://github.com/ascentusoss/barqueiro/issues"
  },
  "keywords": [
    "discord",
    "bot",
    "perfil",
    "ranking",
    "quiz",
    "typescript",
    "sqlite"
  ],
  "engines": {
    "node": ">=20.19.6",
    "npm": ">=10.8.2"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.json && tsc-alias -p ./tsconfig.json && mkdir -p dist/database && cp database/schema.postgres.sql dist/database/",
    "type-check": "tsc --noEmit -p ./tsconfig.json",
    "dev": "node --loader ts-node/esm -r tsconfig-paths/register src/bin/index.ts",
    "dev:bot": "node --loader ts-node/esm -r tsconfig-paths/register src/bot/bin/bot.ts",
    "dev:server": "node --loader ts-node/esm -r tsconfig-paths/register src/server/server.ts",
    "start": "node dist/bin/index.js",
    "start:bot": "node dist/bot/bin/bot.js",
    "start:server": "node dist/server/server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "diagnosticar": "oraculo diagnosticar",
    "formatar": "oraculo formatar --write",
    "fix-types": "oraculo fix-types",
    "scan": "auditor scan",
    "lint": "eslint . --ext .ts,.js --fix",
    "lint:storage": "eslint src/storage --ext .ts --max-warnings 0",
    "lint:yaml": "yamllint .github/workflows/*.yml",
    "format": "npm run format:prettier && npm run format:stylelint && npm run format:sql && npm run lint:yaml",
    "format:prettier": "prettier --write .",
    "format:stylelint": "stylelint \"**/*.{css,scss}\" --config ./node_modules/shared-config/configs/stylelint/.stylelintrc.json --fix --allow-empty-input",
    "format:sql": "sql-formatter -l sqlite -o database/schema.sql database/schema.sql && sql-formatter -l postgresql -o database/schema.postgres.sql database/schema.postgres.sql && sql-formatter -l postgresql -o database/rls-policies.sql database/rls-policies.sql",
    "format:check": "prettier --check . && stylelint \"**/*.{css,scss}\" --config ./node_modules/shared-config/configs/stylelint/.stylelintrc.json --allow-empty-input && npm run db:lint && yamllint .github/workflows/*.yml",
    "db:lint": "node ./scripts/check-sql-format.mjs sqlite database/schema.sql && node ./scripts/check-sql-format.mjs postgresql database/schema.postgres.sql && node ./scripts/check-sql-format.mjs postgresql database/rls-policies.sql",
    "bot:register": "npm run build && node dist/bot/commands/registrar-comandos.js",
    "bot:clean": "npm run build && node dist/bot/commands/registrar-comandos.js --clean",
    "bot:refresh": "npm run bot:clean && npm run bot:register",
    "server:preview": "npx http-server ./public -p 5500",
    "validate:sustainability": "node scripts/validate-sustainability.mjs",
    "audit:licenses": "node scripts/auditar-licencas.mjs"
  },
  "dependencies": {
    "auditor": "file:auditor-0.1.0.tgz",
    "axios": "^1.13.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "glob": "^13.0.3",
    "helmet": "^8.1.0",
    "jose": "^6.1.3",
    "oraculo": "file:oraculo-0.3.8.tgz",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.16.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "shared-config": "file:./shared-config",
    "sql-formatter": "^15.7.0",
    "stylelint": "^17.2.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18",
    "yaml-lint": "^1.7.0"
  },
  "lint-staged": {
    "**/*.ts": ["eslint --fix", "prettier --write"],
    "**/*.css": ["stylelint --fix", "prettier --write"],
    "**/*.html": ["htmlhint", "prettier --write"],
    "database/schema.sql": ["sql-formatter -l sqlite --check"],
    "database/schema.postgres.sql": ["sql-formatter -l postgresql --check"],
    "database/rls-policies.sql": ["sql-formatter -l postgresql --check"],
    ".github/workflows/*.yml": ["prettier --write"],
    "**/*": ["prettier --write --ignore-unknown"]
  }
}
